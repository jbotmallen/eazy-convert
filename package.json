{
  "name": "kitbox-desktop",
  "private": true,
  "version": "1.0.0",
  "description": "Local-first digital toolkit for private media, document, and file workflows.",
  "author": "KitBox Team",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "main": "dist-electron/main.js",
  "scripts": {
    "preinstall": "pnpm dlx only-allow pnpm",
    "setup": "pnpm install --frozen-lockfile",
    "dev": "concurrently -k \"vite\" \"pnpm run dev:electron\"",
    "start": "pnpm run dev:electron",
    "dev:electron": "wait-on tcp:5173 && pnpm run build:main && cross-env NODE_ENV=development electron .",
    "build:main": "tsc -p electron/tsconfig.json",
    "clean": "rimraf dist dist-electron release --glob",
    "build": "vite build",
    "build:web": "vite build",
    "prebuild:desktop": "node scripts/check-ytdlp-version.mjs",
    "build:desktop": "pnpm run clean && vite build && pnpm run build:main && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview",
    "audit:deps": "node scripts/security-audit.mjs",
    "audit:vuln": "pnpm audit --prod --audit-level high",
    "audit:full": "pnpm run audit:deps && pnpm run audit:vuln"
  },
  "build": {
    "appId": "com.eazyconvert.app",
    "productName": "KitBox",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/ffprobe-static/**",
      "**/node_modules/youtube-dl-exec/**",
      "**/node_modules/pdfjs-dist/**",
      "**/node_modules/@imgly/background-removal-node/**",
      "**/node_modules/onnxruntime-node/**"
    ],
    "electronFuses": {
      "runAsNode": false,
      "enableCookieEncryption": true,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "enableEmbeddedAsarIntegrityValidation": true,
      "onlyLoadAppFromAsar": true
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/rnnoise",
        "to": "rnnoise",
        "filter": [
          "*.rnnn"
        ]
      }
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/logo.png",
      "publish": null,
      "signtoolOptions": {
        "publisherName": "KitBox"
      }
    },
    "mac": {
      "target": "dmg",
      "icon": "public/logo.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/logo.png"
    }
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@imgly/background-removal-node": "1.4.5",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-toast": "1.2.15",
    "@tailwindcss/vite": "4.1.18",
    "@types/turndown": "5.0.6",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "ffmpeg-static": "5.3.0",
    "ffprobe-static": "3.1.0",
    "framer-motion": "12.34.2",
    "html-to-docx": "1.8.0",
    "image-size": "1.2.1",
    "jszip": "3.10.1",
    "lucide-react": "0.574.0",
    "mammoth": "1.11.0",
    "marked": "17.0.3",
    "next-themes": "0.4.6",
    "pdf-lib": "1.17.1",
    "pdf-parse": "2.4.5",
    "pdfjs-dist": "5.4.624",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "15.0.0",
    "react-hook-form": "7.71.1",
    "react-router-dom": "7.13.0",
    "sanitize-html": "2.17.4",
    "sonner": "2.0.7",
    "tailwind-merge": "3.4.1",
    "tailwindcss": "4.1.18",
    "turndown": "7.2.2",
    "youtube-dl-exec": "3.1.6",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/ffprobe-static": "2.0.3",
    "@types/html-to-docx": "1.8.0",
    "@types/node": "24.10.13",
    "@types/pdf-parse": "1.1.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "2.16.1",
    "@vitejs/plugin-react": "5.1.4",
    "concurrently": "9.2.1",
    "cross-env": "10.1.0",
    "electron": "40.9.3",
    "electron-builder": "26.7.0",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "16.5.0",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.0",
    "vite": "7.3.2",
    "wait-on": "9.0.4"
  }
}
