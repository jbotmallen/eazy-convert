{
  "name": "eazy-convert-desktop",
  "private": true,
  "version": "1.0.0",
  "description": "Professional-grade desktop utility for fast, private media conversion and YouTube downloading.",
  "author": "EazyConvert Team",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm run dev:electron\"",
    "start": "npm run dev:electron",
    "dev:electron": "wait-on tcp:5173 && npm run build:main && cross-env NODE_ENV=development electron .",
    "build:main": "tsc -p electron/tsconfig.json",
    "clean": "rimraf dist dist-electron release --glob",
    "build": "npm run clean && vite build && npm run build:main && electron-builder",
    "build:web": "vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "overrides": {
    "minimatch@3.1.5": {
      "brace-expansion": "1.1.13"
    }
  },
  "build": {
    "appId": "com.eazyconvert.app",
    "productName": "EazyConvert",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/ffprobe-static/**",
      "**/node_modules/yt-dlp-exec/**",
      "**/node_modules/pdfjs-dist/**"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/logo.png",
      "publish": null
    },
    "mac": {
      "target": "dmg",
      "icon": "public/logo.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/logo.png"
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@tailwindcss/vite": "^4.1.18",
    "@types/turndown": "^5.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "framer-motion": "^12.34.2",
    "html-to-docx": "^1.8.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.574.0",
    "mammoth": "^1.11.0",
    "marked": "^17.0.3",
    "path": "^0.12.7",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.4.624",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.71.1",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.4.1",
    "tailwindcss": "^4.1.18",
    "turndown": "^7.2.2",
    "yt-dlp-exec": "^1.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/ffprobe-static": "^2.0.3",
    "@types/html-to-docx": "^1.8.0",
    "@types/node": "^24.10.13",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
