# Supply-chain hardening — see CLAUDE.md / SECURITY.md.
#
# save-exact: any `npm install <pkg>` writes the exact resolved version to
# package.json (no caret/tilde). Prevents silent minor/patch bumps that have
# repeatedly been the path of npm supply-chain compromises.
save-exact=true

# Lifecycle install scripts are blocked by default for every dependency.
# Only packages listed in `pnpm.onlyBuiltDependencies` in package.json may
# run their install/postinstall hooks. This is the single highest-impact
# mitigation against malicious packages — most npm worms (event-stream,
# ua-parser-js, colors/faker sabotage, the 2024 polyfill compromise,
# the 2025 nx/qix worms) executed via these hooks. The allowlist is the
# canonical pnpm pattern; do not re-enable `ignore-scripts=true` here, it
# would override the allowlist and block trusted rebuilds.

# engine-strict: refuse to install if engines field doesn't match.
engine-strict=true

# fund: silence funding prompts.
fund=false

# node-linker: deliberate Phase A compromise for Electron packaging. A flat
# node_modules layout keeps electron-builder asarUnpack globs and
# getUnpackedPath() assumptions working unchanged; revisit isolated mode in a
# future pnpm hardening phase.
node-linker=hoisted

# minimumReleaseAge: quarantine newly-published versions for 7 days
# (10080 minutes). Cuts the "compromised version published hours ago"
# attack window — most npm supply-chain incidents are detected and yanked
# within 48-72 hours. Applies at resolution time only: `--frozen-lockfile`
# installs read pinned versions and are unaffected. To bypass for a
# specific package, add it to `minimumReleaseAgeExclude`.
minimumReleaseAge=10080
